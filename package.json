{
  "name": "drizzle-databend",
  "module": "./dist/index.mjs",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "version": "0.1.13",
  "description": "A drizzle ORM driver for use with Databend. Based on drizzle's Postgres driver surface.",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --platform=node --packages=external --outfile=dist/index.mjs && npm run build:declarations",
    "build:declarations": "tsc --emitDeclarationOnly --project tsconfig.types.json",
    "test": "vitest run",
    "db:up": "docker-compose up -d --wait",
    "db:down": "docker-compose down",
    "db:destroy": "docker-compose down -v",
    "lint": "biome check src/ test/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "databend-driver": ">=0.33.0",
    "drizzle-orm": ">=0.40.0"
  },
  "peerDependenciesMeta": {
    "databend-driver": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "databend-driver": "^0.33.6",
    "drizzle-orm": "0.45.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.2",
    "vitest": "^1.6.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "drizzle",
    "databend"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cliftonc/drizzle-databend"
  },
  "license": "MIT",
  "files": [
    "src/**/*.ts",
    "dist/*.mjs",
    "dist/**/*.d.ts"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
